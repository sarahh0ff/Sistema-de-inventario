@model IEnumerable<InventaCore.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="app-shell">
    <div class="glass-card">
        <div class="topbar">
            <div>
                <div class="brand-mark">InventaCore</div>
                <h1 class="soft-title mb-0" id="productsTitle">Productos</h1>
            </div>

            <div class="nav-soft">
                <a asp-controller="Productos" asp-action="Create" id="newProductButton">Nuevo producto</a>
                <a asp-controller="Account" asp-action="Logout" id="logoutButton">Cerrar sesión</a>
            </div>
        </div>

        <table class="table-soft" id="productsTable">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>Precio</th>
                    <th>Cantidad</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="productsTableBody">
                @foreach (var item in Model)
                {
                    <tr id="product-row-@item.Id">
                        <td class="product-name">@item.Nombre</td>
                        <td class="product-category">@item.Categoria</td>
                        <td class="product-price">@item.Precio</td>
                        <td class="product-stock">@item.Cantidad</td>
                        <td>
                            <div class="action-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="soft-btn soft-btn-secondary edit-button" data-id="@item.Id">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="soft-btn soft-btn-secondary details-button" data-id="@item.Id">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="soft-btn soft-btn-danger delete-button" data-id="@item.Id">Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>