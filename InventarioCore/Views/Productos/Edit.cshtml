@model InventaCore.Models.Producto

@{
    ViewData["Title"] = "Editar producto";
}

<div class="app-shell">
    <div class="glass-card" style="max-width: 700px; margin: 0 auto;">
        <h1 class="soft-title" id="editTitle">Editar producto</h1>
        <p class="soft-subtitle">Modifica la información del producto seleccionado</p>

        <form asp-action="Edit" method="post" class="form-grid" id="editProductForm">
            <input type="hidden" asp-for="Id" id="productId" />

            <div>
                <label asp-for="Nombre" class="soft-label"></label>
                <input asp-for="Nombre" class="soft-input" id="productName" />
                <span asp-validation-for="Nombre" class="validation-soft" id="productNameValidation"></span>
            </div>

            <div>
                <label asp-for="Categoria" class="soft-label"></label>
                <input asp-for="Categoria" class="soft-input" id="productCategory" />
                <span asp-validation-for="Categoria" class="validation-soft" id="productCategoryValidation"></span>
            </div>

            <div>
                <label asp-for="Precio" class="soft-label"></label>
                <input asp-for="Precio" class="soft-input" id="productPrice" />
                <span asp-validation-for="Precio" class="validation-soft" id="productPriceValidation"></span>
            </div>

            <div>
                <label asp-for="Cantidad" class="soft-label"></label>
                <input asp-for="Cantidad" class="soft-input" id="productQuantity" />
                <span asp-validation-for="Cantidad" class="validation-soft" id="productQuantityValidation"></span>
            </div>

            <div class="action-group mt-3">
                <button type="submit" class="soft-btn soft-btn-primary" id="updateProductButton">
                    Guardar cambios
                </button>
                <a asp-action="Index" class="soft-btn soft-btn-secondary" id="backToListButton">
                    Volver
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}