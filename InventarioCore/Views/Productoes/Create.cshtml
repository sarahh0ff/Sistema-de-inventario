@model InventaCore.Models.Producto

@{
    ViewData["Title"] = "Crear producto";
}

<div class="app-shell">
    <div class="glass-card" style="max-width: 700px; margin: 0 auto;">
        <h1 class="soft-title">Crear producto</h1>
        <p class="soft-subtitle">Agrega un nuevo producto al inventario</p>

        <form asp-action="Create" class="form-grid">
            <div>
                <label asp-for="Nombre" class="soft-label"></label>
                <input asp-for="Nombre" class="soft-input" />
                <span asp-validation-for="Nombre" class="validation-soft"></span>
            </div>

            <div>
                <label asp-for="Categoria" class="soft-label"></label>
                <input asp-for="Categoria" class="soft-input" />
                <span asp-validation-for="Categoria" class="validation-soft"></span>
            </div>

            <div>
                <label asp-for="Precio" class="soft-label"></label>
                <input asp-for="Precio" class="soft-input" />
                <span asp-validation-for="Precio" class="validation-soft"></span>
            </div>

            <div>
                <label asp-for="Cantidad" class="soft-label"></label>
                <input asp-for="Cantidad" class="soft-input" />
                <span asp-validation-for="Cantidad" class="validation-soft"></span>
            </div>

            <div class="action-group mt-2">
                <button type="submit" class="soft-btn soft-btn-primary">Guardar</button>
                <a asp-action="Index" class="soft-btn soft-btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}